export interface Client {
  hello({ hello }: { hello: string }, options?: MethodOptions): Promise<AssembledTransaction<string>>;
  auth({ addr, world }: { addr: string | Address; world: string }, options?: MethodOptions): Promise<AssembledTransaction<string>>;
  get_count(options?: MethodOptions): Promise<AssembledTransaction<number>>;
  inc(options?: MethodOptions): Promise<AssembledTransaction<number>>;
  woid(options?: MethodOptions): Promise<AssembledTransaction<void>>;
  val(options?: MethodOptions): Promise<AssembledTransaction<any>>;
  u32_fail_on_even({ u32_ }: { u32_: number }, options?: MethodOptions): Promise<AssembledTransaction<Result<number, Error>>>;
  u32_({ u32_ }: { u32_: number }, options?: MethodOptions): Promise<AssembledTransaction<number>>;
  i32_({ i32_ }: { i32_: number }, options?: MethodOptions): Promise<AssembledTransaction<number>>;
  i64_({ i64_ }: { i64_: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  /**
   * Example contract method which takes a struct
