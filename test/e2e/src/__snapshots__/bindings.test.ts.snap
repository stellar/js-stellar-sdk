  strukt_hel({ strukt }: { strukt: Test }, options?: MethodOptions): Promise<AssembledTransaction<Array<string>>>;
  strukt({ strukt }: { strukt: Test }, options?: MethodOptions): Promise<AssembledTransaction<Test>>;
  simple({ simple }: { simple: SimpleEnum }, options?: MethodOptions): Promise<AssembledTransaction<SimpleEnum>>;
  complex({ complex }: { complex: ComplexEnum }, options?: MethodOptions): Promise<AssembledTransaction<ComplexEnum>>;
  recursive_enum({ recursive }: { recursive: RecursiveEnum }, options?: MethodOptions): Promise<AssembledTransaction<RecursiveEnum>>;
  addresse({ addresse }: { addresse: string | Address }, options?: MethodOptions): Promise<AssembledTransaction<string>>;
  bytes({ bytes }: { bytes: Buffer }, options?: MethodOptions): Promise<AssembledTransaction<Buffer>>;
  bytes_n({ bytes_n }: { bytes_n: Buffer }, options?: MethodOptions): Promise<AssembledTransaction<Buffer>>;
  card({ card }: { card: RoyalCard }, options?: MethodOptions): Promise<AssembledTransaction<RoyalCard>>;
  boolean({ boolean }: { boolean: boolean }, options?: MethodOptions): Promise<AssembledTransaction<boolean>>;
  /**
   * Negates a boolean value
   */
  not({ boolean }: { boolean: boolean }, options?: MethodOptions): Promise<AssembledTransaction<boolean>>;
  i128({ i128 }: { i128: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  u128({ u128 }: { u128: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  multi_args({ a, b }: { a: number; b: boolean }, options?: MethodOptions): Promise<AssembledTransaction<number>>;
  map({ map }: { map: Map<number, boolean> }, options?: MethodOptions): Promise<AssembledTransaction<Map<number, boolean>>>;
  vec({ vec }: { vec: Array<number> }, options?: MethodOptions): Promise<AssembledTransaction<Array<number>>>;
  tuple({ tuple }: { tuple: [string, number] }, options?: MethodOptions): Promise<AssembledTransaction<[string, number]>>;
  /**
   * Example of an optional argument
   */
  option({ option }: { option: number | null }, options?: MethodOptions): Promise<AssembledTransaction<number | null>>;
  get_object_vec_option(options?: MethodOptions): Promise<AssembledTransaction<Array<Test> | null>>;
  u256({ u256 }: { u256: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  i256({ i256 }: { i256: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  string({ string }: { string: string }, options?: MethodOptions): Promise<AssembledTransaction<string>>;
  tuple_strukt({ tuple_strukt }: { tuple_strukt: TupleStruct }, options?: MethodOptions): Promise<AssembledTransaction<TupleStruct>>;
  timepoint({ timepoint }: { timepoint: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
  duration({ duration }: { duration: bigint }, options?: MethodOptions): Promise<AssembledTransaction<bigint>>;
}

