exports[`Bindings Snapshot Test > generates bindings that match snapshot for custom-types contract > custom-types-types.ts 1`] = `
"import {Address} from '@stellar/stellar-sdk';

    /**
 * This is from the rust doc above the struct Test
 */
export interface Test {
  a: number;
  b: boolean;
  c: string;
}

/**
 * Union: SimpleEnum
 */
 export type SimpleEnum =
  { tag: "First"; values: void } |
  { tag: "Second"; values: void } |
  { tag: "Third"; values: void };

/**
 * Enum: RoyalCard
 */
export enum RoyalCard {
  /**
   * Enum Case: Jack
   */
  Jack = 11,
  /**
   * Enum Case: Queen
   */
  Queen = 12,
  /**
   * Enum Case: King
   */
  King = 13
}

/**
 * Tuple Struct: TupleStruct
 */
export type TupleStruct = readonly [Test, SimpleEnum];

/**
 * Union: ComplexEnum
 */
 export type ComplexEnum =
  { tag: "Struct"; values: readonly [Test] } |
  { tag: "Tuple"; values: readonly [TupleStruct] } |
  { tag: "Enum"; values: readonly [SimpleEnum] } |
  { tag: "Asset"; values: readonly [string, bigint] } |
  { tag: "Void"; values: void };

/**
 * Union: RecursiveEnum
 */
 export type RecursiveEnum =
  { tag: "List"; values: readonly [Array<RecursiveEnum>] } |
  { tag: "Void"; values: void };

/**
 * Error Enum: Error
 */
export const Error = {
  /**
   * Please provide an odd number
   */
  1 : { message: "NumberMustBeOdd" }
}

/**
 * Error Enum: Erroneous
 */
export const Erroneous = {
  /**
   * Some contract libraries contain extra #[contracterror] definitions that end up compiled
   * into the main contract types. We need to make sure tooling deals with this properly.
   */
  100 : { message: "HowCouldYou" }
}
    "
`;
