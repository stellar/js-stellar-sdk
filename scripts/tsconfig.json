  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["ES2022"],
    "module": "Node20",
    "moduleResolution": "node16",
    "target": "es2022",
    "types": ["node"]
  },
  "include": ["./**/*.ts"]
}
