{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "lib/esm",
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["ES2022", "DOM"],
    "module": "Node20",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "lib/esm",
    "target": "es2022",
    "types": ["node", "base32.js", "js-xdr-v4"],
    "typeRoots": ["types", "node_modules/@types"],
    "importHelpers": false
  },
  "include": ["src"],
  "exclude": ["src/content.config.ts", "src/content/**"]
}
