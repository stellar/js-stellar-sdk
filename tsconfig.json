{
  "extends": "@stellar/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "lib/esm",
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["ES2022", "DOM"],
    "module": "Node20",
    "moduleResolution": "node16",
    "rootDir": "src",
    "outDir": "lib/esm",
    "target": "es2022",
    "types": ["node", "base32.js", "stellar__js-xdr"],
    "typeRoots": ["types", "node_modules/@types"]
  },
  "include": ["src"],
  "exclude": [
    "src/base/generated/curr_generated.js",
    "src/base/generated/next_generated.js",
    "src/content.config.ts",
    "src/content/**"
  ]
}
