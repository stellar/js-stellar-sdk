set -e

echo ""
echo "▶ Verifying generated docs are up to date…"
echo ""

pnpm run docs:reference
pnpm run docs:llms

# Only docs/reference/* and docs/index.md are committed generated docs.
# docs/guides/* and docs/agents.md are hand-written inputs — exclude them so an
# uncommitted source edit isn't misreported as stale generated output.
# --porcelain (vs git diff) also catches brand-new untracked generated files,
# and status is relative to HEAD so staged-but-uncommitted docs still block.
STALE=$(git status --porcelain --untracked-files=all -- \
  docs/ ':(exclude)docs/guides' ':(exclude)docs/agents.md' \
  ':(exclude)docs/llms.txt' ':(exclude)docs/llms-full.txt')

if [ -n "$STALE" ]; then
  echo "$STALE"
  echo ""
  echo "✗ Generated docs are out of date or uncommitted. Run 'pnpm run docs', then stage & commit the generated changes under docs/."
  echo ""
  exit 1
fi

echo ""
echo "✓ Generated docs are up to date."
echo ""
