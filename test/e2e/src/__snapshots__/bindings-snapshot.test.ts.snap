exports[`Bindings Generation Snapshot Tests > custom-types contract bindings > types.ts matches snapshot > custom-types-types.ts 1`] = `
"import {Address} from '@stellar/stellar-sdk';

    /**
 * This is from the rust doc above the struct Test
 */
export interface Test {
  a: number;
  b: boolean;
  c: string;
}

/**
 * Union: SimpleEnum
 */
 export type SimpleEnum =
  { tag: "First" } |
  { tag: "Second" } |
  { tag: "Third" };

/**
 * Enum: RoyalCard
 */
export enum RoyalCard {
  /**
   * Enum Case: Jack
   */
  Jack = 11,
  /**
   * Enum Case: Queen
   */
  Queen = 12,
  /**
   * Enum Case: King
   */
  King = 13
}

/**
 * Struct: TupleStruct
 */
export interface TupleStruct {
  0: Test;
  1: SimpleEnum;
}

/**
 * Union: ComplexEnum
 */
 export type ComplexEnum =
  { tag: "Struct"; values: readonly [Test] } |
  { tag: "Tuple"; values: readonly [TupleStruct] } |
  { tag: "Enum"; values: readonly [SimpleEnum] } |
  { tag: "Asset"; values: readonly [string | Address, bigint] } |
  { tag: "Void" };

/**
 * Error Enum: Error
 */
export const Error = {
  /**
   * Please provide an odd number
   */
  1 : { message: "NumberMustBeOdd" }
}
    "
`;

exports[`Bindings Generation Snapshot Tests > increment contract bindings > client.ts matches snapshot > increment-client.ts 1`] = `
"import {Spec, AssembledTransaction, Client as ContractClient, ClientOptions as ContractClientOptions, MethodOptions} from '@stellar/stellar-sdk/contract';

export interface Client {
  /**
   * Increment internal counter, return the value
   */
  increment(options?: MethodOptions): Promise<AssembledTransaction<number>>;
  /**
   * Get current counter value
   */
  get(options?: MethodOptions): Promise<AssembledTransaction<number>>;
}

export class Client extends ContractClient {
  constructor(public readonly options: ContractClientOptions) {
    super(
      new Spec(["AAAAAAAAACNJbml0aWFsaXplIHRoZSBjb3VudGVyIHdpdGggYSB2YWx1ZQAAAAANX19jb25zdHJ1Y3RvcgAAAAAAAAEAAAAAAAAAB2NvdW50ZXIAAAAABAAAAAA=", "AAAAAAAAACxJbmNyZW1lbnQgaW50ZXJuYWwgY291bnRlciwgcmV0dXJuIHRoZSB2YWx1ZQAAAAlpbmNyZW1lbnQAAAAAAAAAAAAAAQAAAAQ=", "AAAAAAAAABlHZXQgY3VycmVudCBjb3VudGVyIHZhbHVlAAAAAAAAA2dldAAAAAAAAAAAAQAAAAQ="]),
      options
    );
  }

   static deploy<T = Client>({ counter }: { counter: number }, options: MethodOptions & Omit<ContractClientOptions, 'contractId'> & { wasmHash: Buffer | string; salt?: Buffer | Uint8Array; format?: "hex" | "base64"; address?: string; }): Promise<AssembledTransaction<T>> {
    return ContractClient.deploy({ counter }, options);
  }
  public readonly fromJSON = {
    increment : this.txFromJSON<number>,  get : this.txFromJSON<number>
  };
}"
`;

