{
  "extends": "@stellar/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "../lib/types",
    "removeComments": false,
    "lib": ["ES2022", "DOM"],
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": "../src",
